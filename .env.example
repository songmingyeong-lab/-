# PostgreSQL connection string. Do not commit real credentials.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/garibong_dashboard?schema=public"

# Seoul Open Data Plaza key. Required only when DATA_MODE=live.
SEOUL_OPEN_API_KEY=""

# mock | live
DATA_MODE="mock"
SAVE_RAW_RESPONSES="false"

# Enables POST /api/collection/run only when set to a strong secret.
COLLECTION_ADMIN_TOKEN=""
