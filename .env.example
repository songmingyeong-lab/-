# Runtime PostgreSQL connection. For Vercel, use the Supabase transaction pooler
# (port 6543) and keep pgbouncer=true in the query string.
DATABASE_URL="postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Prisma migrations, seed, and pg_dump. Use the Supabase direct connection or
# session pooler (port 5432). Do not use the transaction pooler for migrations.
DIRECT_URL="postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Optional project metadata. Prisma does not need a Supabase API key in phase 1.
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_PROJECT_ID="PROJECT_REF"

# Seoul Open Data Plaza key. Required only when DATA_MODE=live.
SEOUL_OPEN_API_KEY=""
PUBLIC_DATA_PORTAL_SERVICE_KEY=""

# mock | live
DATA_MODE="mock"
SAVE_RAW_RESPONSES="false"

# Enables POST /api/collection/run only when set to a strong secret.
COLLECTION_ADMIN_TOKEN=""

# Vercel automatically sends this as `Authorization: Bearer <CRON_SECRET>`.
# Use a different random value from COLLECTION_ADMIN_TOKEN (minimum 16 chars).
CRON_SECRET=""
